ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_MINIMUM_REQUESTS=60
ALERT_WINDOW_SECONDS=300
RUNBOOK_DIRECTORY=/runbooks
COMMIT_FIXTURE_PATH=/scenarios/checkout-commits.json
SCENARIO_DIRECTORY=/scenarios
AUTO_INVESTIGATE_INCIDENTS=true
INVESTIGATION_HTTP_TIMEOUT_SECONDS=5
AUTO_GENERATE_PROPOSALS=true
SYNTHESIS_PROVIDER=auto
