PAGERAGENT_CONNECTOR_DECRYPTION_KEYS={}
PAGERAGENT_CONNECTOR_ALLOWED_ORIGINS=https://api.github.com,https://slack.com,http://prometheus:9090,http://localhost:9090
GITHUB_EVIDENCE_MODE=auto
GITHUB_API_VERSION=2026-03-10
GITHUB_HTTP_TIMEOUT_SECONDS=5
GITHUB_MAX_RESPONSE_BYTES=1048576
GITHUB_MAX_API_REQUESTS=24
GITHUB_MAX_COMMITS=8
GITHUB_MAX_RELATED_ITEMS=10
GITHUB_EVIDENCE_LOOKBACK_HOURS=24
PROMETHEUS_EVIDENCE_MODE=auto
PROMETHEUS_HTTP_TIMEOUT_SECONDS=6
PROMETHEUS_MAX_RESPONSE_BYTES=1048576
PROMETHEUS_MAX_SERIES=50
PROMETHEUS_MAX_SAMPLES=2000
PROMETHEUS_MAX_LABELS_PER_SERIES=16
PROMETHEUS_MAX_WINDOW_SECONDS=1800
PROMETHEUS_QUERY_STEP_SECONDS=15
PAGERAGENT_TELEMETRY_ALLOWED_ORIGINS=http://checkout-api:8100
DATABASE_URL=postgresql+psycopg://pageragent:pageragent@postgres:5432/pageragent
REDIS_URL=redis://redis:6379/0
WORKFLOW_STREAM_NAME=pageragent.workflows
WORKFLOW_CONSUMER_GROUP=pageragent-workers
