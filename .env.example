PAGERAGENT_ENV=local
DATABASE_URL=postgresql+psycopg://pageragent:pageragent@postgres:5432/pageragent
REDIS_URL=redis://redis:6379/0
OPENAI_API_KEY=
SLACK_WEBHOOK_URL=
GITHUB_TOKEN=
BACKEND_CORS_ORIGINS=http://localhost:5173
CHECKOUT_API_URL=http://checkout-api:8100
PAGERAGENT_API_URL=http://backend:8000
ALERT_ERROR_RATE_THRESHOLD=0.05
ALERT_MINIMUM_REQUESTS=60
ALERT_WINDOW_SECONDS=300
RUNBOOK_DIRECTORY=/runbooks
COMMIT_FIXTURE_PATH=/scenarios/checkout-commits.json
AUTO_INVESTIGATE_INCIDENTS=true
INVESTIGATION_HTTP_TIMEOUT_SECONDS=5
AUTO_GENERATE_PROPOSALS=true
SYNTHESIS_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OPENAI_BASE_URL=https://api.openai.com/v1
SYNTHESIS_HTTP_TIMEOUT_SECONDS=30
CHECKOUT_CONTROL_URL=http://checkout-api:8100
RECOVERY_CANARY_REQUESTS=15
AUTO_GENERATE_POSTMORTEMS=true
